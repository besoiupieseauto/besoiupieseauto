; Copy this to .env and fill in real values.

; --- WhatsApp (UltraMsg) ---
ULTRAMSG_INSTANCE = instanceXXXXXX
ULTRAMSG_TOKEN = your_ultramsg_token
WEBHOOK_KEY = pick_a_long_random_string

; --- OpenAI ---
OPENAI_KEY = sk-...
OPENAI_MODEL = gpt-4o-mini
OPENAI_KEY_VIN = sk-...
OPENAI_MODEL_VIN = gpt-5.4

; --- Groq ---
GROQ_KEY = gsk_...
GROQ_MODEL = llama-3.3-70b-versatile

; --- Apify ---
APIFY_TOKEN = apify_api_...
APIFY_FB_ACTOR = apify/facebook-groups-scraper
FB_GROUP_URL = https://www.facebook.com/groups/dezmebrari/

; --- RapidAPI ---
RAPIDAPI_TECDOC_KEY = your_rapidapi_key_for_tecdoc_and_allegro2
RAPIDAPI_AUTOPARTS_KEY = your_rapidapi_key_for_auto_parts_catalog

; --- Allegro pricing ---
EXCHANGE_RATE_PLN_RON = 1.17
MARKUP_PERCENT = 30

; --- pieseauto.ro user (optional) ---
PIESEAUTO_USER =

; --- DB (shared with EvaSystem admin) ---
DB_HOST = localhost
DB_NAME = besoiupieseauto.ro
DB_USER = root
DB_PASS =
