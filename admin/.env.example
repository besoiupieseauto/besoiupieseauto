APP_ENV=development
APP_URL=https://besoiupieseauto.ro

# Mod la cerere (recomandat): 1 = fără API în fundal/cron/site; doar cache local + apeluri explicite din admin.
# 0 = permite consum automat (cron, site fără cache, agenți). CLI one-shot: BESOIU_API_LIVE_OVERRIDE=1 php ...
API_AUTOMATION_DISABLED=1

# Webhook plată online (obligatoriu în producție)
PAYMENT_WEBHOOK_KEY=

# Criptare credențiale conturi PieseAuto.ro (AES-256-GCM; generează 32+ caractere random)
PIESEAUTO_CREDENTIAL_KEY=

DB_HOST=127.0.0.1
DB_NAME=besoiupieseauto.ro
DB_USER=root
DB_PASS=

# Baza secundara pentru modulul "Caiet de comenzi" (Laravel legacy).
LEGACY_DB_HOST=127.0.0.1
LEGACY_DB_NAME=caietcom_comenzilv
LEGACY_DB_USER=root
LEGACY_DB_PASS=

OPENAI_KEY=
IMAGE_AUDIT_ENGINE=cursor
IMAGE_AUDIT_MODEL=gpt-4o-mini
# Cursor API — audit imagini direct din admin (fără copiere prompt)
# Generează la: https://cursor.com/dashboard → Integrations / API Keys
CURSOR_API_KEY=
CURSOR_MODEL=composer-2.5
# Opțional — cale completă python.exe dacă „py” nu e în PATH (Windows Laragon):
# CURSOR_PYTHON=F:/laragon/bin/python/python-3.13/python.exe

# Ollama — LLM local (metro: Ollama first, Cursor la escaladare)
# Instalare Windows: irm https://ollama.com/install.ps1 | iex
# Apoi: ollama pull qwen2.5:3b
OLLAMA_ENABLED=1
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_LOCAL_CYCLE=1
LLM_ROUTER_MODE=ollama_first

OPENAI_MODEL=gpt-4o-mini
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-2.0-flash
GROK_MODEL=grok-2-1212

# Surse căutare imagine la import/cron (ordine = prioritate)
# Valori: caietcomenzi, tecdoc_csv, epiesa, emag, tecdoc_api, pieseauto
IMAGE_SEARCH_SOURCES=caietcomenzi,epiesa,autodoc,tecdoc_api
# La update produs cu audit „replace” — re-caută imagine din surse
IMAGE_AUDIT_AUTO_RETRY=0
# ePiesa la cron import (lent ~90s/produt — necesită SCRAPE_DO_TOKEN)
CRON_CHECK_EPIESA=0
GROQ_KEY=
SERPAPI_KEY=
APIFY_TOKEN=

# scrape.do — Scraper ePiesa + imagini eMAG la import (Coada Import). Nu commita tokenul în git.
SCRAPE_DO_TOKEN=

# RapidAPI: auto-parts-catalog (TecDoc) — necesar pentru imagini când CSV-ul nu are TTC Art ID
# Abonează-te la: https://rapidapi.com/auto-parts-catalog/api/auto-parts-catalog
RAPIDAPI_AUTOPARTS_KEY=
RAPIDAPI_TECDOC_KEY=

# Token pentru agentul local supplier_sync (PC -> upload pe server)
SUPPLIER_SYNC_TOKEN=

# Cron HTTP refresh dashboard snapshot: header X-Dashboard-Cron-Key sau GET ?key= (legacy)
DASHBOARD_CRON_KEY=
AI_AGENT_CRON_KEY=

# Cron Sync — import automat furnizori (admin/cron)
CRON_IMPORT_MODE=dual
CRON_IMPORT_LIMIT=10
CRON_CATALOG_LIMIT=20
CRON_VITRINA_LIMIT=8
CRON_LIGHT_ENRICH=1
CRON_SKIP_TECDOC_CSV=1
CRON_CHECK_EPIESA=0
CRON_AUTO_PUBLISH=1
CRON_SCAN_LOCK_MAX_SEC=600
CRON_DASHBOARD_JOBS=installed

# CORS pentru API publice (ex. categorii site). Virgulă = liste; * = doar dev
CORS_ALLOWED_ORIGINS=https://besoiupieseauto.ro,https://www.besoiupieseauto.ro

# Mod preview storefront — site public blocat fără cheie (?key=...)
# SITE_PREVIEW_LOCK_ALL=1 → blochează și /admin + /robot (webhook/cron/sync rămân deschise)
SITE_PREVIEW_MODE=0
SITE_PREVIEW_KEY=
SITE_PREVIEW_LOCK_ALL=0
SITE_PREVIEW_COOKIE_DAYS=30
SITE_PREVIEW_FORCE=0

# PHP CLI: activați ext-zip pentru phpoffice/phpword (composer install)

# MOD TEST doar factura SmartBill + AWB curier (dezactivat implicit)
FULFILLMENT_TEST_MODE=0
FULFILLMENT_SMARTBILL_ENABLED=1
FULFILLMENT_AWB_ENABLED=1
FULFILLMENT_DEFAULT_COURIER=fancourier
FULFILLMENT_TEST_SERIES=TEST
FULFILLMENT_TEST_INVOICE_PREFIX=TEST-INV
FULFILLMENT_TEST_AWB_PREFIX=TEST-AWB

SMARTBILL_API_URL=https://ws.smartbill.ro/SBZ/api
SMARTBILL_API_KEY=
SMARTBILL_USER_EMAIL=
SMARTBILL_COMPANY_VAT=RO31298897
SMARTBILL_SERIES_NAME=BPA_CAI

FANCOURIER_API_URL=https://api.fancourier.ro
FANCOURIER_USERNAME=
FANCOURIER_PASSWORD=
FANCOURIER_CLIENT_ID=
FANCOURIER_SERVICE_STANDARD=Standard
FANCOURIER_SERVICE_COD=Cont Colector
FANCOURIER_COST_CENTER=WEB

SAMEDAY_API_URL=https://api.sameday.ro
SAMEDAY_USERNAME=
SAMEDAY_PASSWORD=
SAMEDAY_PICKUP_POINT_ID=
SAMEDAY_SERVICE_ID=7

# Provisioning FTP/email furnizori — vezi admin/config/hosting_provision.local.php
