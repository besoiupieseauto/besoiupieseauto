# =====================
# DirectoryIndex — PHP înainte de index.html static (template demo)
# =====================
DirectoryIndex index.php index.html

# =====================
# URL Rewrite Setup
# =====================
RewriteEngine On
RewriteBase /admin/

# /admin/assets/* → public/assets/* (fișiere EvaSystem; admin/assets/ e alt set legacy)
RewriteRule ^assets/(.*)$ public/assets/$1 [L]

# /admin/api/* → public/api/* (endpoint-uri JSON EvaSystem)
RewriteRule ^api/(.*)$ public/api/$1 [L]

# ——— BYPASS pentru endpointul API (crududoc) ———
RewriteCond %{REQUEST_URI} ^/public/crududoc(?:\.php)?/?$ [OR]
RewriteCond %{REQUEST_URI} ^/crududoc(?:\.php)?/?$
RewriteRule ^ - [L]

# Cron Sync UI — prioritate față de orice folder fizic admin/cron/ (conflict Apache)
RewriteRule ^cron/?$ public/index.php [L,QSA]
RewriteRule ^cron/index\.php$ public/index.php [L,QSA]

# Nu rescrie dacă există fișier/dir fizic
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
# Lasă /admin/public/* către public/.htaccess (logout.php, index.php EvaSystem)
RewriteCond %{REQUEST_URI} !^/admin/public/
# Front controller EvaSystem — URL-uri curate /admin/* (fără /public/ în browser)
RewriteRule ^(.*)$ public/index.php [QSA,L]

# =====================
# Font MIME Types
# =====================
AddType application/font-woff2 .woff2
AddType application/font-woff  .woff
AddType application/x-font-ttf .ttf

# =====================
# Font Compression
# =====================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE font/woff font/woff2 font/ttf
</IfModule>

# =====================
# PHP Error Display and Logging
# =====================
php_flag display_errors on
php_flag log_errors on
php_value error_log logs/php_errors.log

# =====================
# Font Caching
# =====================
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType application/font-woff2 "access plus 1 year"
  ExpiresByType application/font-woff  "access plus 1 year"
  ExpiresByType application/x-font-ttf "access plus 1 year"
</IfModule>

# =====================
# Security Headers (CSP compatibil TinyMCE + amCharts + AnimCube3 eval)
# =====================
<IfModule mod_headers.c>
  # Curăță CSP-uri vechi (evită dubluri)
  Header always unset Content-Security-Policy
  Header always unset Content-Security-Policy-Report-Only

  # CSP: permite tinymce + amCharts de pe CDN-urile lor + scripturi inline + unsafe-eval (AnimCube3)
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; frame-ancestors 'self' https://meet.jit.si; frame-src 'self' https://besoiupieseauto.ro https://www.besoiupieseauto.ro; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.tiny.cloud https://cdn.amcharts.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://unpkg.com https://cdn.tiny.cloud; img-src 'self' data: blob: https://cdn.tiny.cloud https://cdn.amcharts.com; media-src 'self' data: blob:; font-src 'self' data: https://fonts.gstatic.com https://fonts.googleapis.com https://unpkg.com https://cdn.tiny.cloud https://cdn.amcharts.com; connect-src 'self' https://cdn.tiny.cloud https://cdn.amcharts.com https://static.cloudflareinsights.com; form-action 'self'"

  # Alte headere utile
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "no-referrer"

  # CORS (opțional; ajustează după nevoie)
  Header set Access-Control-Allow-Origin "*"
  Header set Access-Control-Allow-Methods "GET, POST, OPTIONS"
  Header set Access-Control-Allow-Headers "Content-Type, Authorization"
</IfModule>

# =====================
# File Protection
# =====================
<Files .htaccess>
  Order allow,deny
  Deny from all
</Files>

<FilesMatch "\.(env|ini|log|sh|bak|sql)$">
  Order allow,deny
  Deny from all
</FilesMatch>

# =====================
# Directory Browsing
# =====================
Options -Indexes
