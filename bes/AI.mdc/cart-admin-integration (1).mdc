## FAZA 2: SOLUȚIA COMPLETĂ DE IMPLEMENTAT

### 2.1 Schema DB — asigură aceste coloane

```sql
-- Tabela cart_items (sesiuni active de cumpărare)
CREATE TABLE IF NOT EXISTS cart_items (
    id INT AUTO_INCREMENT PRIMARY KEY,
    session_id VARCHAR(128) NOT NULL,
    user_id INT NULL,
    product_id INT NOT NULL,
    product_name VARCHAR(255) NOT NULL,
    product_image VARCHAR(500),  -- ⚠️ OBLIGATORIU pentru a nu pierde imaginea
    price DECIMAL(10,2) NOT NULL,
    quantity INT NOT NULL DEFAULT 1,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    INDEX idx_session (session_id),
    INDEX idx_user (user_id),
    FOREIGN KEY (product_id) REFERENCES products(id) ON DELETE CASCADE
);

-- Tabela order_items trebuie să stocheze și imaginea (snapshot la momentul comenzii)
ALTER TABLE order_items ADD COLUMN IF NOT EXISTS product_image VARCHAR(500);
ALTER TABLE order_items ADD COLUMN IF NOT EXISTS product_name VARCHAR(255);
```

### 2.2 Endpoint backend — `api/add_to_cart.php`

```php
<?php
session_start();
header('Content-Type: application/json; charset=utf-8');
require_once __DIR__ . '/../config/database.php';

try {
    $productId = (int)($_POST['product_id'] ?? 0);
    $quantity = max(1, (int)($_POST['quantity'] ?? 1));

    if ($productId <= 0) {
        throw new Exception('ID produs invalid');
    }

    // Preia datele produsului din DB (NU avea încredere în ce vine din frontend pentru preț!)
    $stmt = $pdo->prepare("SELECT id, name, price, image, stock FROM products WHERE id = ?");
    $stmt->execute([$productId]);
    $product = $stmt->fetch(PDO::FETCH_ASSOC);

    if (!$product) {
        throw new Exception('Produs inexistent');
    }

    if ($product['stock'] < $quantity) {
        throw new Exception('Stoc insuficient');
    }

    $sessionId = session_id();
    $userId = $_SESSION['user_id'] ?? null;

    // Verifică dacă produsul e deja în coș
    $check = $pdo->prepare("SELECT id, quantity FROM cart_items WHERE session_id = ? AND product_id = ?");
    $check->execute([$sessionId, $productId]);
    $existing = $check->fetch(PDO::FETCH_ASSOC);

    if ($existing) {
        $upd = $pdo->prepare("UPDATE cart_items SET quantity = quantity + ?, updated_at = NOW() WHERE id = ?");
        $upd->execute([$quantity, $existing['id']]);
    } else {
        // Insert nou — SALVĂM și imaginea ca să nu se piardă
        $ins = $pdo->prepare("
            INSERT INTO cart_items (session_id, user_id, product_id, product_name, product_image, price, quantity)
            VALUES (?, ?, ?, ?, ?, ?, ?)
        ");
        $ins->execute([
            $sessionId,
            $userId,
            $product['id'],
            $product['name'],
            $product['image'],  // ⚠️ IMAGINEA — nu o lăsa pe dinafară
            $product['price'],
            $quantity
        ]);
    }

    // Calculează totalul de produse pentru badge
    $count = $pdo->prepare("SELECT COALESCE(SUM(quantity), 0) FROM cart_items WHERE session_id = ?");
    $count->execute([$sessionId]);
    $totalItems = (int)$count->fetchColumn();

    echo json_encode([
        'success' => true,
        'message' => 'Produs adăugat în coș',
        'cart_count' => $totalItems,
        'product' => [
            'id' => $product['id'],
            'name' => $product['name'],
            'image' => $product['image'],
            'price' => $product['price'],
            'quantity' => $quantity
        ]
    ]);

} catch (Exception $e) {
    http_response_code(400);
    echo json_encode(['success' => false, 'message' => $e->getMessage()]);
}
```

### 2.3 JS Frontend — `assets/js/cart.js`

```javascript
document.addEventListener('DOMContentLoaded', () => {
    // Atașează handler la TOATE butoanele .btn_addtoccard
    document.querySelectorAll('.btn_addtoccard').forEach(btn => {
        btn.addEventListener('click', async (e) => {
            e.preventDefault();

            // Găsește product_id din atribut data-* sau din contextul cardului
            const productCard = btn.closest('[data-product-id]') || btn.closest('.product-card');
            const productId = btn.dataset.productId || productCard?.dataset.productId;
            const quantity = btn.dataset.quantity || 1;

            if (!productId) {
                console.error('Nu s-a găsit product_id pentru butonul:', btn);
                return;
            }

            btn.disabled = true;

            try {
                const formData = new FormData();
                formData.append('product_id', productId);
                formData.append('quantity', quantity);

                const res = await fetch('/api/add_to_cart.php', {
                    method: 'POST',
                    body: formData
                });

                const data = await res.json();

                if (data.success) {
                    updateCartBadge(data.cart_count);
                    showCartPopup(data.product);
                } else {
                    alert(data.message || 'Eroare la adăugare');
                }
            } catch (err) {
                console.error(err);
                alert('Eroare de rețea');
            } finally {
                btn.disabled = false;
            }
        });
    });

    // La încărcarea paginii, sincronizează badge-ul
    syncCartBadge();
});

function updateCartBadge(count) {
    let badge = document.querySelector('.cart-badge');
    const link = document.querySelector('._home-user-link[href="cart.php"]');

    if (!link) return;

    if (!badge) {
        badge = document.createElement('span');
        badge.className = 'cart-badge';
        link.style.position = 'relative';
        link.appendChild(badge);
    }

    badge.textContent = count;
    badge.style.display = count > 0 ? 'inline-block' : 'none';
}

async function syncCartBadge() {
    try {
        const res = await fetch('/api/get_cart_count.php');
        const data = await res.json();
        if (data.success) updateCartBadge(data.count);
    } catch (e) {
        console.error('Eroare sync badge:', e);
    }
}

function showCartPopup(product) {
    document.querySelector('.cart-popup')?.remove();

    const popup = document.createElement('div');
    popup.className = 'cart-popup';
    popup.innerHTML = `
        <div class="cart-popup-content">
            <button class="cart-popup-close" aria-label="Închide">&times;</button>
            <h3>✓ Produs adăugat în coș</h3>
            <div class="cart-popup-product">
                <img src="${product.image}" alt="${product.name}">
                <div>
                    <p class="cart-popup-name">${product.name}</p>
                    <p class="cart-popup-price">${product.price} RON × ${product.quantity}</p>
                </div>
            </div>
            <div class="cart-popup-actions">
                <button class="btn-continue">Continuă cumpărăturile</button>
                <a href="cart.php" class="btn-go-cart">Mergi la coș</a>
            </div>
        </div>
    `;
    document.body.appendChild(popup);

    popup.querySelector('.cart-popup-close').onclick = () => popup.remove();
    popup.querySelector('.btn-continue').onclick = () => popup.remove();

    // Auto-close după 5 secunde
    setTimeout(() => popup.remove(), 5000);
}
```

